{
  "expo": {
    "name": "solarsnap",
    "slug": "solarsnap",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "SolarSnap needs camera access to photograph the sky for solar assessment."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "SolarSnap uses your location to calculate the sun's position at your site."
        }
      ],
      "expo-secure-store",
      "expo-localization",
      "expo-in-app-purchases"
    ]
  }
}
